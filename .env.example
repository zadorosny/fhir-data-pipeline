# --- Postgres (compartilhado: HAPI + Airflow metadata) -----------------------
POSTGRES_USER=fhir
POSTGRES_PASSWORD=change-me-fhir-pass
POSTGRES_DB=fhir
POSTGRES_PORT=5432

# --- Airflow -----------------------------------------------------------------
# Role Postgres dedicada (separada do owner do HAPI) — princípio de menor privilégio
AIRFLOW_DB_USER=airflow_user
AIRFLOW_DB_PASSWORD=change-me-airflow-db-pass
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change-me-airflow-pass
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_PORT=8081
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=change-me-fernet-key-32-bytes-base64
# Gere com: openssl rand -hex 32
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-flask-secret
# Webhook opcional para alertas de falha (Slack, Teams, custom)
ALERT_WEBHOOK_URL=

# --- HAPI FHIR ---------------------------------------------------------------
HAPI_PORT=8080
HAPI_BASE_URL=http://hapi-fhir:8080/fhir

# --- Kafka -------------------------------------------------------------------
KAFKA_BROKER=kafka:9092
KAFKA_PORT=9092
KAFKA_UI_PORT=9091
KAFKA_TOPIC=fhir-patients
KAFKA_DLQ_TOPIC=fhir-patients-dlq

# --- ETL ---------------------------------------------------------------------
CSV_PATH=/opt/app/data/patients.csv
CSV_ENCODING=ISO-8859-1
CONSUMER_TIMEOUT_MS=15000
HAPI_RETRY_ATTEMPTS=30
HAPI_RETRY_DELAY=2
FHIR_POST_MAX_RETRIES=5
FHIR_POST_BACKOFF=0.5
METRICS_PORT=8001
LOG_LEVEL=INFO

# --- Observabilidade (stack opcional: --profile monitoring) ------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-pass
